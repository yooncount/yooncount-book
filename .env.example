# ----------------------------------------
# 1. 이 파일을 .env 로 복사하세요.
#    cp .env.example .env
#
# 2. .env 는 절대 Git에 커밋하지 마세요.
#    (.gitignore 에 이미 등록되어 있습니다)
# ----------------------------------------

# --- PostgreSQL ---
DB_USER=yooncount
DB_PASSWORD=your_secure_password_here

# --- GitHub 오류 신고 ---
# 앱 내 오류 신고 → 지정 레포에 이슈 자동 등록
# 발급: GitHub → Settings → Developer settings → Personal access tokens (Fine-grained)
# 권한: 대상 레포에 대한 Issues(Read and write) 만 필요
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=ps-suihn-yoon
GITHUB_REPO_NAME=yooncount-book

# --- Finnhub 등 사용자 비밀 설정 암호화 키 ---
# 생성: openssl rand -base64 32
# 분실 시 DB의 모든 암호화 값 복호화 불가 — 안전한 곳에 백업 필수
APP_ENCRYPTION_KEY=

# --- JWT 서명 키 ---
# 생성: openssl rand -base64 64
# 분실/변경 시 발급된 모든 토큰 무효화 (전체 강제 로그아웃)
JWT_SECRET=
