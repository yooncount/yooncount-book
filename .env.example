# ----------------------------------------
# 1. 이 파일을 .env 로 복사하세요.
#    cp .env.example .env
#
# 2. .env 는 절대 Git에 커밋하지 마세요.
#    (.gitignore 에 이미 등록되어 있습니다)
# ----------------------------------------

# PostgreSQL 비밀번호 — 반드시 변경하세요
DB_PASSWORD=your_secure_password_here

# Finnhub API 키 — 환경변수 불필요 (앱 설정 페이지에서 직접 등록)
# 발급: https://finnhub.io → 회원가입 → Dashboard → API Key 복사
# 무료 플랜: 분당 60회 요청 가능 (개인 사용에 충분)

# GitHub 오류 신고 토큰 — 앱 내 오류 신고 기능에 필요합니다
# 발급: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 권한: Issues(Read and write) 만 부여하면 됩니다.
# 토큰 발급은 yooncount@gmail.com에 문의하세요.
GITHUB_TOKEN=your_github_token_here
